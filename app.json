{
  "expo": {
    "name": "My Weather",
    "slug": "myweather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/app/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#006666"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#006666"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rabiibenrioui.myweather"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/app/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1c1c77a3-9487-4b9c-8b21-dab0b4ba0ee9"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
